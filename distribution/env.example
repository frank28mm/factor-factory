# Copy this file to `.env` if you want to override defaults.

FACTOR_FACTORY_ROOT=.
FACTOR_FACTORY_PYTHON=python3

# WQ / browser session
# Leave blank to auto-detect an already-open logged-in WorldQuant BRAIN tab.
WQ_TARGET_ID=

# Loop settings
FACTOR_FACTORY_RUN_ID=factor-factory-local
FACTOR_FACTORY_INTERVAL_SECONDS=15
FACTOR_FACTORY_MAX_RUNNING=3
FACTOR_FACTORY_PENDING_REFRESH_LIMIT=3
FACTOR_FACTORY_WAITING_REFRESH_LIMIT=5
FACTOR_FACTORY_SUBMIT_READY_LIMIT=4
FACTOR_FACTORY_PROBE_BATCH_LIMIT=3
FACTOR_FACTORY_PROBE_RATE_LIMIT_COOLDOWN_SECONDS=180
FACTOR_FACTORY_RATE_LIMIT_COOLDOWN_SECONDS=600
